---
layout: vanilla.njk
---

{% set archiveItems = collections.archives | sort(attribute="data.title") %}

{% set allThemes = [] %}
{% for archive in archiveItems %}
  {% if archive.data.themes %}
    {% for theme in archive.data.themes %}
      {% if theme and theme not in allThemes %}
        {% set allThemes = allThemes.concat([theme]) %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endfor %}

{% set countArchival = 0 %}
{% set countBiblio = 0 %}
{% set countPubs = 0 %}
{% for archive in archiveItems %}
  {% if archive.data.section == 'bibliography' %}
    {% set countBiblio = countBiblio + 1 %}
  {% elif archive.data.section == 'publications' %}
    {% set countPubs = countPubs + 1 %}
  {% else %}
    {% set countArchival = countArchival + 1 %}
  {% endif %}
{% endfor %}

{# Split into explicitly ordered (have data.order) and rest (title-sorted) #}
{% set featuredOrdered = [] %}
{% set featuredRest = [] %}
{% for archive in archiveItems %}
  {% if archive.data.order %}
    {% set featuredOrdered = featuredOrdered.concat([archive]) %}
  {% elif archive.data.thumbnail %}
    {% set featuredRest = featuredRest.concat([archive]) %}
  {% endif %}
{% endfor %}
{% set featuredOrdered = featuredOrdered | sort(false, false, 'data.order') %}

<section class="home-hero vault-zone">
  <div class="container-xl">
    <h1 class="home-hero__title">{{ site.hero.title }}</h1>
    <p class="home-hero__mission">{% if page.lang == 'en' %}{{ site.hero.subtitle_en }}{% else %}{{ site.hero.subtitle_es }}{% endif %}</p>
  </div>
</section>

<div class="wrapper home">
  <div class="content">

    <section class="home-search section-band">
      <div class="container-xl">
        <div id="search"></div>
      </div>
    </section>

    <section class="home-sections section-band">
      <div class="container-xl">
        <div class="row g-4">

          <div class="col-lg-4 col-md-6 d-flex">
            <a href="{{ '/archives/' | sitePath }}" class="section-card-link d-flex flex-fill">
              <div class="section-card flex-fill">
                <p class="section-card__eyebrow">{% if page.lang == 'en' %}Section{% else %}Sección{% endif %}</p>
                <h2 class="section-card__title">{% if page.lang == 'en' %}Archival &amp; Primary Materials{% else %}Materiales archivísticos y primarios{% endif %}</h2>
                <p class="section-card__count">{{ countArchival }} {% if page.lang == 'en' %}{% if countArchival == 1 %}collection{% else %}collections{% endif %}{% else %}{% if countArchival == 1 %}colección{% else %}colecciones{% endif %}{% endif %}</p>
              </div>
            </a>
          </div>

          <div class="col-lg-4 col-md-6 d-flex">
            <a href="{{ '/archives/' | sitePath }}" class="section-card-link d-flex flex-fill">
              <div class="section-card flex-fill">
                <p class="section-card__eyebrow">{% if page.lang == 'en' %}Section{% else %}Sección{% endif %}</p>
                <h2 class="section-card__title">{% if page.lang == 'en' %}Research Library / Bibliography{% else %}Biblioteca de investigación{% endif %}</h2>
                <p class="section-card__count">{{ countBiblio }} {% if page.lang == 'en' %}{% if countBiblio == 1 %}collection{% else %}collections{% endif %}{% else %}{% if countBiblio == 1 %}colección{% else %}colecciones{% endif %}{% endif %}</p>
              </div>
            </a>
          </div>

          <div class="col-lg-4 col-md-6 d-flex">
            <a href="{{ '/archives/' | sitePath }}" class="section-card-link d-flex flex-fill">
              <div class="section-card flex-fill">
                <p class="section-card__eyebrow">{% if page.lang == 'en' %}Section{% else %}Sección{% endif %}</p>
                <h2 class="section-card__title">{% if page.lang == 'en' %}Project Publications{% else %}Publicaciones del proyecto{% endif %}</h2>
                <p class="section-card__count">{{ countPubs }} {% if page.lang == 'en' %}{% if countPubs == 1 %}collection{% else %}collections{% endif %}{% else %}{% if countPubs == 1 %}colección{% else %}colecciones{% endif %}{% endif %}</p>
              </div>
            </a>
          </div>

        </div>
      </div>
    </section>

    {% if allThemes.length > 0 %}
    <section class="home-themes section-band">
      <div class="container-xl">
        <div class="home-themes__row">
          <span class="home-themes__label">{% if page.lang == 'en' %}Themes{% else %}Temas{% endif %}</span>
          {% for theme in allThemes %}
          <a href="{{ '/archives/' | sitePath }}" class="ui-chip home-theme-chip">{{ theme }}</a>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    <section class="home-featured section-band">
      <div class="container-xl">
        <div class="section-title">
          <h2>{% if page.lang == 'en' %}Primary Sources{% else %}Fuentes primarias{% endif %}</h2>
        </div>
        <div class="row g-4 archive-grid">
          {%- set featuredCount = 0 -%}
          {%- for archive in featuredOrdered -%}
          {%- if featuredCount < 6 -%}
          {% set archiveTitle = archive.data.titleEng if page.lang == 'en' and archive.data.titleEng else archive.data.title %}
          <div class="col-xl-4 col-md-6 d-flex">
            <a href="{{ archive.url | sitePath }}" class="archive-card-link d-flex flex-fill">
              <article class="doc-frame">
                <div class="doc-frame__media">
                  {% if archive.data.thumbnail %}
                  <img src="{{ archive.data.thumbnail | sitePath }}" class="img-fluid" alt="{{ archiveTitle }}">
                  {% endif %}
                </div>
                <div class="doc-frame__body">
                  <h3 class="doc-frame__title">{{ archive.data.shortTitle or archiveTitle }}</h3>
                  {% if archive.data.themes %}
                  <p class="doc-frame__breadcrumb">{{ archive.data.themes | join(' · ') }}</p>
                  {% endif %}
                  {% set cardSummary = archive.data['summary-en'] if page.lang == 'en' and archive.data['summary-en'] else archive.data['summary-es'] %}{% if cardSummary %}<p class="doc-frame__summary">{{ cardSummary }}</p>{% endif %}
                </div>
              </article>
            </a>
          </div>
          {%- set featuredCount = featuredCount + 1 -%}
          {%- endif -%}
          {%- endfor -%}
          {%- for archive in featuredRest -%}
          {%- if featuredCount < 6 -%}
          {% set archiveTitle = archive.data.titleEng if page.lang == 'en' and archive.data.titleEng else archive.data.title %}
          <div class="col-xl-4 col-md-6 d-flex">
            <a href="{{ archive.url | sitePath }}" class="archive-card-link d-flex flex-fill">
              <article class="doc-frame">
                <div class="doc-frame__media">
                  {% if archive.data.thumbnail %}
                  <img src="{{ archive.data.thumbnail | sitePath }}" class="img-fluid" alt="{{ archiveTitle }}">
                  {% endif %}
                </div>
                <div class="doc-frame__body">
                  <h3 class="doc-frame__title">{{ archive.data.shortTitle or archiveTitle }}</h3>
                  {% if archive.data.themes %}
                  <p class="doc-frame__breadcrumb">{{ archive.data.themes | join(' · ') }}</p>
                  {% endif %}
                  {% set cardSummary = archive.data['summary-en'] if page.lang == 'en' and archive.data['summary-en'] else archive.data['summary-es'] %}{% if cardSummary %}<p class="doc-frame__summary">{{ cardSummary }}</p>{% endif %}
                </div>
              </article>
            </a>
          </div>
          {%- set featuredCount = featuredCount + 1 -%}
          {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </section>

  </div>
</div>
