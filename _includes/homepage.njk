---
layout: vanilla.njk
---

{% set archiveItems = collections.archives %}

<section class="home-hero vault-zone">
  <div class="container-xl">
    <h1 class="home-hero__title">{{ site.hero.title }}</h1>
    <p class="home-hero__mission">{% if page.lang == 'en' %}{{ site.hero.subtitle_en }}{% else %}{{ site.hero.subtitle_es }}{% endif %}</p>
  </div>
</section>

<div class="wrapper home">
  <div class="content">

    <section class="home-search section-band">
      <div class="container-xl">
        <div id="search"></div>
      </div>
    </section>

    <section class="home-colecciones section-band">
      <div class="container-xl">
        <h2 class="home-colecciones__heading">{% if page.lang == 'en' %}Collections{% else %}Colecciones{% endif %}</h2>
        <div class="row g-4">
          {%- for col in colecciones.colecciones -%}
          {%- set colName = col.name_en if page.lang == 'en' else col.name_es -%}
          {%- set colDesc = col.description_en if page.lang == 'en' and col.description_en else col.description_es -%}
          {%- set colItems = [] -%}
          {%- for archive in archiveItems -%}
            {%- if archive.data.themes and col.name_es in archive.data.themes -%}{%- set colItems = colItems.concat([archive]) -%}{%- endif -%}
          {%- endfor -%}
          {%- if colItems.length -%}
          {%- set colImage = col.image -%}
          {%- for a in colItems -%}{%- if not colImage and a.data.thumbnail -%}{%- set colImage = a.data.thumbnail -%}{%- endif -%}{%- endfor -%}
          <div class="col-lg-4 col-md-6 d-flex">
            <a href="{{ ('/colecciones/' + col.slug + '/') | sitePath }}" class="section-card-link d-flex flex-fill">
              <div class="section-card flex-fill">
                {% if colImage %}<div class="section-card__media"><img src="{{ colImage | sitePath }}" alt="{{ colName }}"></div>{% endif %}
                <p class="section-card__eyebrow">{% if page.lang == 'en' %}Collection{% else %}Colección{% endif %}</p>
                <h3 class="section-card__title">{{ colName }}</h3>
                {% if colDesc %}<p class="section-card__summary">{{ colDesc }}</p>{% endif %}
              </div>
            </a>
          </div>
          {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </section>

  </div>
</div>
