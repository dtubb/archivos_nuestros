<!DOCTYPE html>
<html lang="{{ page.lang }}">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>{{ title or metadata.title }}</title>
  <meta content="" name="description">
  <meta content="" name="keywords">

  <!-- Favicons -->
  <link href="/assets/img/favicon.png" rel="icon">
  <link href="/assets/img/apple-touch-icon.png" rel="apple-touch-icon">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,500;1,600;1,700;1,800&family=Marcellus:wght@400&display=swap" rel="stylesheet">

  <!-- Vendor CSS Files -->
  <link href="/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="/assets/vendor/aos/aos.css" rel="stylesheet">
  <link href="/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">
  <link href="/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">

  <!-- Main CSS File -->
  <link href="/assets/css/main.css" rel="stylesheet">

  {% block extracss %}{% endblock %}

  <!-- pagefind files -->
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
  <script src="/pagefind/pagefind-ui.js" type="text/javascript"></script>


  <!-- =======================================================
  * Template Name: AgriCulture
  * Template URL: https://bootstrapmade.com/agriculture-bootstrap-website-template/
  * Updated: Jun 29 2024 with Bootstrap v5.3.3
  * Author: BootstrapMade.com
  * License: https://bootstrapmade.com/license/
  ======================================================== -->
</head>

<body class="index-page">

{% set archiveCount = collections.archives | length %}
{% set exhibitCount = collections.exhibits | length %}

<header>
 {% include "navbar.njk" %}
</header>

  <main class="main">
    
    <section class="archivos-hero section">
      <div class="container">
        <div class="row justify-content-between g-4 align-items-start">
          <div class="col-lg-7">
            <p class="eyebrow">{% if page.lang == 'en' %}Working preview{% else %}Vista previa de trabajo{% endif %}</p>
            <h1 class="hero-title">{% if page.lang == 'en' %}Archivos Nuestros{% else %}Archivos Nuestros{% endif %}</h1>
            <p class="hero-lede">
              {% if page.lang == 'en' %}
              A bilingual research site for curated primary sources, project publications, and linked research materials focused in part on the Colombian Pacific.
              {% else %}
              Un sitio bilingüe de investigación para fuentes primarias curadas, publicaciones del proyecto y materiales de investigación vinculados, centrado en parte en el Pacífico colombiano.
              {% endif %}
            </p>
            <p class="hero-copy">
              {% if page.lang == 'en' %}
              This site is being rebuilt in public. The framework, taxonomy, and metadata model are being revised first; collections will then move over one at a time, with review and enrichment.
              {% else %}
              Este sitio se está reconstruyendo en público. Primero se revisan la estructura, la taxonomía y el modelo de metadatos; luego las colecciones se trasladarán una por una, con revisión y enriquecimiento.
              {% endif %}
            </p>
          </div>
          <div class="col-lg-4">
            <div class="hero-panel">
              <h2>{% if page.lang == 'en' %}Current public sections{% else %}Secciones públicas actuales{% endif %}</h2>
              <ul>
                <li>{% if page.lang == 'en' %}Archival and Primary Materials{% else %}Materiales de Archivo y Fuentes Primarias{% endif %}</li>
                <li>{% if page.lang == 'en' %}Project Publications{% else %}Publicaciones del Proyecto{% endif %}</li>
                <li>{% if page.lang == 'en' %}Research Library / Bibliography{% else %}Biblioteca de Investigación / Bibliografía{% endif %}</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="row g-4 mt-2">
          <div class="col-lg-4">
            <div class="overview-card h-100">
              <h3>{% if page.lang == 'en' %}Thematic areas{% else %}Áreas temáticas{% endif %}</h3>
              <ul>
                <li>Minería en el Chocó Colombiano</li>
                <li>Mapas</li>
                <li>En clave afro-diaspórica: Historia, cultura, visiones</li>
                <li>Palenke el Congal</li>
                <li>Archivo Catherine Legrande</li>
              </ul>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="overview-card h-100">
              <h3>{% if page.lang == 'en' %}Publication streams{% else %}Líneas de publicación{% endif %}</h3>
              <ul>
                <li>{% if page.lang == 'en' %}Short digital essays{% else %}Ensayos digitales breves{% endif %}</li>
                <li>{% if page.lang == 'en' %}Working papers{% else %}Documentos de trabajo{% endif %}</li>
                <li>{% if page.lang == 'en' %}Maps we have made{% else %}Mapas producidos por el proyecto{% endif %}</li>
                <li>{% if page.lang == 'en' %}Booklets and exhibits{% else %}Cartillas y exposiciones{% endif %}</li>
              </ul>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="overview-card h-100">
              <h3>{% if page.lang == 'en' %}Collection workflow{% else %}Flujo de trabajo por colección{% endif %}</h3>
              <ul>
                <li>{% if page.lang == 'en' %}Review source material{% else %}Revisar el material fuente{% endif %}</li>
                <li>{% if page.lang == 'en' %}Draft metadata in YAML and JSONL{% else %}Redactar metadatos en YAML y JSONL{% endif %}</li>
                <li>{% if page.lang == 'en' %}Prepare thumbnails, rights, and storage handoff{% else %}Preparar miniaturas, derechos y entrega para almacenamiento{% endif %}</li>
                <li>{% if page.lang == 'en' %}Publish one reviewed collection at a time{% else %}Publicar una colección revisada a la vez{% endif %}</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="about section archivos-about">
      <div class="container">
        <div class="row g-4">
          <div class="col-lg-6">
            <h2>{% if page.lang == 'en' %}About the project{% else %}Sobre el proyecto{% endif %}</h2>
            <p>
              {% if page.lang == 'en' %}
              Archivos Nuestros is becoming a bilingual repository for historians, anthropologists, geographers, archivists, and related publics. It will bring together curated primary sources, project publications, and linked bibliographic materials while keeping track of provenance, rights, and hosting decisions.
              {% else %}
              Archivos Nuestros se está convirtiendo en un repositorio bilingüe para historiadores, antropólogos, geógrafos, archivistas y otros públicos afines. Reunirá fuentes primarias curadas, publicaciones del proyecto y materiales bibliográficos vinculados, manteniendo registro de procedencia, derechos y decisiones de alojamiento.
              {% endif %}
            </p>
            <p>
              {% if page.lang == 'en' %}
              The current build is intentionally text-forward. It is meant to make structure, metadata, and review workflow visible before the full set of collections comes online.
              {% else %}
              La construcción actual es intencionalmente más textual. Busca hacer visibles la estructura, los metadatos y el flujo de revisión antes de que entre en línea el conjunto completo de colecciones.
              {% endif %}
            </p>
          </div>
          <div class="col-lg-6">
            <h2>{% if page.lang == 'en' %}People{% else %}Personas{% endif %}</h2>
            <div class="people-summary">
              <h3>Ann Farnsworth-Alvear</h3>
              <p>{% if page.lang == 'en' %}Historian at the University of Pennsylvania working on labor, extraction, and oral history in Colombia and Angola.{% else %}Historiadora en la Universidad de Pensilvania que trabaja sobre trabajo, extracción e historia oral en Colombia y Angola.{% endif %}</p>
              <h3>Daniel Tubb</h3>
              <p>{% if page.lang == 'en' %}Anthropologist at the University of New Brunswick whose research focuses on Colombia, extractive projects, and rural life in the Chocó and beyond.{% else %}Antropólogo en la Universidad de New Brunswick cuya investigación se centra en Colombia, los proyectos extractivos y la vida rural en el Chocó y más allá.{% endif %}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="archives" class="recent-posts section">
      <div class="container section-title" >
        <h2>{% if page.lang == 'en' %}Archival and Primary Materials{% else %}Materiales de Archivo y Fuentes Primarias{% endif %}</h2>
      </div>

      <div class="container">
      {% if archiveCount == 0 %}
        <div class="empty-state">
          <p>{% if page.lang == 'en' %}No collection is published in this section yet. The first reviewed collection will appear here as materials move over one at a time.{% else %}Todavía no hay ninguna colección publicada en esta sección. La primera colección revisada aparecerá aquí a medida que los materiales se trasladen uno por uno.{% endif %}</p>
        </div>
      {% else %}
        <div class="row gy-5 mt-0">
        {%- for archive in collections.archives | sort(attribute="data.title") -%}
          <div class="archive-item col-xl-4 col-md-6" data-category="{{ archive.data.type }}">

            <div class="post-item position-relative h-100" data-aos-delay="100">

              <div class="post-img position-relative overflow-hidden">
                <img src="{{ archive.data.thumbnail }}" class="img-fluid" alt="{{ archive.data.title }}">
                {% if archive.data.date %}
                <span class="post-date">{{ archive.data.date }}</span>
                {% endif %}
              </div>

              <div class="post-content d-flex flex-column">
              <!-- insert the Type if available -->  
             {% if archive.data.type %}
              <div class="pb-3">
                <span class="badge text-white bg-primary">{{ archive.data.type }}</span>
              </div>
              {% endif %}
              <!-- use English language title if available when site is in English mode -->
                {% if page.lang == 'en' %}
                  {% if archive.data.titleEng %}
                  <h3 class="post-title">{{ archive.data.titleEng }}</h3>
                  {% else %}
                  <h3 class="post-title">{{ archive.data.title }}</h3>
                  {% endif %}
                {% else %}
                <h3 class="post-title">{{ archive.data.title }}</h3>
                {% endif %}

                <div class="meta d-flex align-items-center">
                  <div class="d-flex align-items-center">
                    <i class="bi bi-person"></i> <span class="ps-2">{{ archive.data.author }}</span>
                  </div>
                  {% if archive.data.topic %}
                    <span class="px-3 text-black-50">/</span>
                    <div class="d-flex align-items-center">
                      <i class="bi bi-folder2"></i> <span class="ps-2">{{ archive.data.topic }}</span>
                    </div>
                  {% endif %}
                </div>

                <hr>

                <a href="{{ archive.data.link or archive.url }}" class="readmore stretched-link">
                  <span>{% if page.lang == 'en' %}Read more{% else %}Lee más{% endif %}</span><i class="bi bi-arrow-right"></i>
                </a>

              </div>

            </div>
          </div><!-- End post item -->
          {% endfor %}
          
        </div>
      {% endif %}
      </div>
    </section>

    <section id="exhibits" class="recent-posts section">
      <div class="container section-title" >
        <h2>{% if page.lang == 'en' %}Project Publications{% else %}Publicaciones del Proyecto{% endif %}</h2>
      </div>

      <div class="container">
        {% if exhibitCount == 0 %}
        <div class="empty-state">
          <p>{% if page.lang == 'en' %}This section will hold short digital essays, working papers, maps we have made, booklets, and exhibits published through Archivos Nuestros.{% else %}Esta sección alojará ensayos digitales breves, documentos de trabajo, mapas elaborados por el proyecto, cartillas y exposiciones publicadas por Archivos Nuestros.{% endif %}</p>
        </div>
        {% else %}
        <div class="row gy-5">
            {%- for exhibit in collections.exhibits -%}

          <div class="col-xl-4 col-md-6">
            <div class="post-item position-relative h-100"  data-aos-delay="100">

              <div class="post-img position-relative overflow-hidden">
                <img src="{{ exhibit.data.thumbnail }}" class="img-fluid" alt="{{ exhibit.data.title }}">
                <span class="post-date">{{ exhibit.data.date }}</span>
              </div>

              <div class="post-content d-flex flex-column">
                            
              <!-- use English language title if available when site is in English mode -->
                              {% if page.lang == 'en' %}
                  {% if archive.data.titleEng %}
                  <h3 class="post-title">{{ exhibit.data.titleEng }}</h3>
                  {% else %}
                  <h3 class="post-title">{{ exhibit.data.title }}</h3>
                  {% endif %}
                {% else %}
                <h3 class="post-title">{{ exhibit.data.title }}</h3>
                {% endif %}

                <div class="meta d-flex align-items-center">
                  <div class="d-flex align-items-center">
                    <i class="bi bi-person"></i> <span class="ps-2">{{ exhibit.data.author }}</span>
                  </div>
                  <span class="px-3 text-black-50">/</span>
                  <div class="d-flex align-items-center">
                    <i class="bi bi-folder2"></i> <span class="ps-2">{{ exhibit.data.topic }}</span>
                  </div>
                </div>

                <hr>

                <a href="{{ exhibit.data.link or exhibit.url }}" class="readmore stretched-link">
                  <span>{% if page.lang == 'en' %}Read more{% else %}Lee más{% endif %}</span><i class="bi bi-arrow-right"></i>
                </a>

              </div>

            </div>
          </div><!-- End post item -->
          {% endfor %}
          
        </div>
        {% endif %}
      </div>
    </section>

    <section class="section bibliography-section">
      <div class="container section-title">
        <h2>{% if page.lang == 'en' %}Research Library / Bibliography{% else %}Biblioteca de Investigación / Bibliografía{% endif %}</h2>
      </div>
      <div class="container">
        <div class="empty-state">
          <p>{% if page.lang == 'en' %}This section will gather linked or hosted dissertations, blogs, scholarly articles, bibliographies, and related secondary materials.{% else %}Esta sección reunirá tesis, blogs, artículos académicos, bibliografías y otros materiales secundarios, ya sea enlazados o alojados localmente.{% endif %}</p>
        </div>
      </div>
    </section>


  </main>

<div id="search-modal" class="modal modal-xl" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="search" class="search"></div>
      </div>
      
    </div>
  </div>
</div>

  {% include 'footer.njk' %}

  <!-- Scroll Top -->
  <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

  <!-- Preloader -->
  <div id="preloader"></div>

  <!-- Vendor JS Files -->
  <script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/assets/vendor/php-email-form/validate.js"></script>
  <script src="/assets/vendor/aos/aos.js"></script>
  <script src="/assets/vendor/swiper/swiper-bundle.min.js"></script>
  <script src="/assets/vendor/glightbox/js/glightbox.min.js"></script>

  <!-- Main JS File -->
  <script src="/assets/js/main.js"></script>
  <script>
    window.addEventListener('DOMContentLoaded', (event) => {
        new PagefindUI({ element: "#search", showSubResults: true });
        let myModal = new bootstrap.Modal(document.getElementById('search-modal'), {
          keyboard: false
        })
        document.getElementById('search-icon').addEventListener('click', function() {
          myModal.show();
        });

    });
  </script>
  {% block extrajs %}{% endblock %}

</body>

</html>
