<!DOCTYPE html>
<html lang="{{ page.lang }}">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>{{ title or metadata.title or 'Archivos Nuestros' }}</title>
  <meta content="" name="description">
  <meta content="" name="keywords">

  <!-- Favicons -->
  <link href="{{ '/assets/img/apple-touch-icon.png' | sitePath }}" rel="icon">
  <link href="{{ '/assets/img/apple-touch-icon.png' | sitePath }}" rel="apple-touch-icon">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,500;1,600;1,700;1,800&family=Marcellus:wght@400&display=swap" rel="stylesheet">

  <!-- Vendor CSS Files -->
  <link href="{{ '/assets/vendor/bootstrap/css/bootstrap.min.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/bootstrap-icons/bootstrap-icons.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/aos/aos.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/swiper/swiper-bundle.min.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/glightbox/css/glightbox.min.css' | sitePath }}" rel="stylesheet">

  <!-- Main CSS File -->
  <link href="{{ '/assets/css/main.css' | sitePath }}" rel="stylesheet">

  {% block extracss %}{% endblock %}

  <!-- pagefind files -->
  <link href="{{ '/pagefind/pagefind-ui.css' | sitePath }}" rel="stylesheet">
  <script src="{{ '/pagefind/pagefind-ui.js' | sitePath }}" type="text/javascript"></script>


  <!-- =======================================================
  * Template Name: AgriCulture
  * Template URL: https://bootstrapmade.com/agriculture-bootstrap-website-template/
  * Updated: Jun 29 2024 with Bootstrap v5.3.3
  * Author: BootstrapMade.com
  * License: https://bootstrapmade.com/license/
  ======================================================== -->
</head>

<body class="index-page">

{% set archiveCount = collections.archives | length %}
{% set exhibitCount = collections.exhibits | length %}

<header>
 {% include "navbar.njk" %}
</header>

  <main class="main">
    
    <section class="archivos-hero section">
      <div class="container">
        <div class="row justify-content-between g-4 align-items-start">
          <div class="col-lg-7">
            <h1 class="hero-title">Archivos Nuestros</h1>
          </div>
          <div class="col-lg-4">
            <div class="hero-panel">
              <h2>{% if page.lang == 'en' %}Current public sections{% else %}Secciones públicas actuales{% endif %}</h2>
              <ul>
                <li>{% if page.lang == 'en' %}Archival and Primary Materials{% else %}Materiales de Archivo y Fuentes Primarias{% endif %}</li>
                <li>{% if page.lang == 'en' %}Project Publications{% else %}Publicaciones del Proyecto{% endif %}</li>
                <li>{% if page.lang == 'en' %}Research Library / Bibliography{% else %}Biblioteca de Investigación / Bibliografía{% endif %}</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="row g-4 mt-2">
          <div class="col-lg-4">
            <div class="overview-card h-100">
              <h3>{% if page.lang == 'en' %}Thematic areas{% else %}Áreas temáticas{% endif %}</h3>
              <ul>
                <li>Minería en el Chocó Colombiano</li>
                <li>Mapas</li>
                <li>En clave afro-diaspórica: Historia, cultura, visiones</li>
                <li>Palenke el Congal</li>
                <li>Archivo Catherine Legrande</li>
              </ul>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="overview-card h-100">
              <h3>{% if page.lang == 'en' %}Publication streams{% else %}Líneas de publicación{% endif %}</h3>
              <ul>
                <li>{% if page.lang == 'en' %}Short digital essays{% else %}Ensayos digitales breves{% endif %}</li>
                <li>{% if page.lang == 'en' %}Working papers{% else %}Documentos de trabajo{% endif %}</li>
                <li>{% if page.lang == 'en' %}Maps we have made{% else %}Mapas producidos por el proyecto{% endif %}</li>
                <li>{% if page.lang == 'en' %}Booklets and exhibits{% else %}Cartillas y exposiciones{% endif %}</li>
              </ul>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="overview-card h-100">
              <h3>{% if page.lang == 'en' %}Project{% else %}Proyecto{% endif %}</h3>
              <ul>
                <li>Ann Farnsworth-Alvear</li>
                <li>Daniel Tubb</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="archives" class="recent-posts section">
      <div class="container section-title" >
        <h2>{% if page.lang == 'en' %}Archival and Primary Materials{% else %}Materiales de Archivo y Fuentes Primarias{% endif %}</h2>
      </div>

      <div class="container">
      {% if archiveCount > 0 %}
        <div class="row gy-5 mt-0">
        {%- for archive in collections.archives | sort(attribute="data.title") -%}
          <div class="archive-item col-xl-4 col-md-6" data-category="{{ archive.data.type }}">

            <div class="post-item position-relative h-100" data-aos-delay="100">

              <div class="post-img position-relative overflow-hidden">
                <img src="{{ archive.data.thumbnail | sitePath }}" class="img-fluid" alt="{{ archive.data.title }}">
                {% if archive.data.date %}
                <span class="post-date">{{ archive.data.date }}</span>
                {% endif %}
              </div>

              <div class="post-content d-flex flex-column">
              <!-- insert the Type if available -->  
             {% if archive.data.type %}
              <div class="pb-3">
                <span class="badge text-white bg-primary">{{ archive.data.type }}</span>
              </div>
              {% endif %}
              <!-- use English language title if available when site is in English mode -->
                {% if page.lang == 'en' %}
                  {% if archive.data.titleEng %}
                  <h3 class="post-title">{{ archive.data.titleEng }}</h3>
                  {% else %}
                  <h3 class="post-title">{{ archive.data.title }}</h3>
                  {% endif %}
                {% else %}
                <h3 class="post-title">{{ archive.data.title }}</h3>
                {% endif %}

                <div class="meta d-flex align-items-center">
                  <div class="d-flex align-items-center">
                    <i class="bi bi-person"></i> <span class="ps-2">{{ archive.data.author }}</span>
                  </div>
                  {% if archive.data.topic %}
                    <span class="px-3 text-black-50">/</span>
                    <div class="d-flex align-items-center">
                      <i class="bi bi-folder2"></i> <span class="ps-2">{{ archive.data.topic }}</span>
                    </div>
                  {% endif %}
                </div>

                <hr>

                <a href="{{ archive.data.link or archive.url }}" class="readmore stretched-link">
                  <span>{% if page.lang == 'en' %}Read more{% else %}Lee más{% endif %}</span><i class="bi bi-arrow-right"></i>
                </a>

              </div>

            </div>
          </div><!-- End post item -->
          {% endfor %}
          
        </div>
      {% endif %}
      </div>
    </section>

    <section id="exhibits" class="recent-posts section">
      <div class="container section-title" >
        <h2>{% if page.lang == 'en' %}Project Publications{% else %}Publicaciones del Proyecto{% endif %}</h2>
      </div>

      <div class="container">
        {% if exhibitCount > 0 %}
        <div class="row gy-5">
            {%- for exhibit in collections.exhibits -%}

          <div class="col-xl-4 col-md-6">
            <div class="post-item position-relative h-100"  data-aos-delay="100">

              <div class="post-img position-relative overflow-hidden">
                <img src="{{ exhibit.data.thumbnail | sitePath }}" class="img-fluid" alt="{{ exhibit.data.title }}">
                <span class="post-date">{{ exhibit.data.date }}</span>
              </div>

              <div class="post-content d-flex flex-column">
                            
              <!-- use English language title if available when site is in English mode -->
                              {% if page.lang == 'en' %}
                  {% if archive.data.titleEng %}
                  <h3 class="post-title">{{ exhibit.data.titleEng }}</h3>
                  {% else %}
                  <h3 class="post-title">{{ exhibit.data.title }}</h3>
                  {% endif %}
                {% else %}
                <h3 class="post-title">{{ exhibit.data.title }}</h3>
                {% endif %}

                <div class="meta d-flex align-items-center">
                  <div class="d-flex align-items-center">
                    <i class="bi bi-person"></i> <span class="ps-2">{{ exhibit.data.author }}</span>
                  </div>
                  <span class="px-3 text-black-50">/</span>
                  <div class="d-flex align-items-center">
                    <i class="bi bi-folder2"></i> <span class="ps-2">{{ exhibit.data.topic }}</span>
                  </div>
                </div>

                <hr>

                <a href="{{ exhibit.data.link or exhibit.url }}" class="readmore stretched-link">
                  <span>{% if page.lang == 'en' %}Read more{% else %}Lee más{% endif %}</span><i class="bi bi-arrow-right"></i>
                </a>

              </div>

            </div>
          </div><!-- End post item -->
          {% endfor %}
          
        </div>
        {% endif %}
      </div>
    </section>

    <section class="section bibliography-section">
      <div class="container section-title">
        <h2>{% if page.lang == 'en' %}Research Library / Bibliography{% else %}Biblioteca de Investigación / Bibliografía{% endif %}</h2>
      </div>
      <div class="container">
        <div class="empty-state"></div>
      </div>
    </section>


  </main>

<div id="search-modal" class="modal modal-xl" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="search" class="search"></div>
      </div>
      
    </div>
  </div>
</div>

  {% include 'footer.njk' %}

  <!-- Scroll Top -->
  <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

  <!-- Preloader -->
  <div id="preloader"></div>

  <!-- Vendor JS Files -->
  <script src="{{ '/assets/vendor/bootstrap/js/bootstrap.bundle.min.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/php-email-form/validate.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/aos/aos.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/swiper/swiper-bundle.min.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/glightbox/js/glightbox.min.js' | sitePath }}"></script>

  <!-- Main JS File -->
  <script src="{{ '/assets/js/main.js' | sitePath }}"></script>
  <script>
    window.addEventListener('DOMContentLoaded', (event) => {
        new PagefindUI({ element: "#search", showSubResults: true });
        let myModal = new bootstrap.Modal(document.getElementById('search-modal'), {
          keyboard: false
        })
        document.getElementById('search-icon').addEventListener('click', function() {
          myModal.show();
        });

    });
  </script>
  {% block extrajs %}{% endblock %}

</body>

</html>
