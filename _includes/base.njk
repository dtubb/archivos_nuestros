<!DOCTYPE html>
<html lang="{{ page.lang }}">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>{{ title or metadata.title or 'Archivos Nuestros' }}</title>
  <meta content="" name="description">
  <meta content="" name="keywords">

  <!-- Favicons -->
  <link href="{{ '/assets/img/apple-touch-icon.png' | sitePath }}" rel="icon">
  <link href="{{ '/assets/img/apple-touch-icon.png' | sitePath }}" rel="apple-touch-icon">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=IM+Fell+English:ital@0;1&family=Inconsolata:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Vendor CSS Files -->
  <link href="{{ '/assets/vendor/bootstrap/css/bootstrap.min.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/bootstrap-icons/bootstrap-icons.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/aos/aos.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/swiper/swiper-bundle.min.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/glightbox/css/glightbox.min.css' | sitePath }}" rel="stylesheet">

  <!-- Main CSS File -->
  <link href="{{ '/assets/css/main.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/css/archivos.css' | sitePath }}" rel="stylesheet">

  {% block extracss %}{% endblock %}

  <!-- pagefind files -->
  <link href="{{ '/pagefind/pagefind-ui.css' | sitePath }}" rel="stylesheet">
  <script src="{{ '/pagefind/pagefind-ui.js' | sitePath }}" type="text/javascript"></script>


  <!-- =======================================================
  * Template Name: AgriCulture
  * Template URL: https://bootstrapmade.com/agriculture-bootstrap-website-template/
  * Updated: Jun 29 2024 with Bootstrap v5.3.3
  * Author: BootstrapMade.com
  * License: https://bootstrapmade.com/license/
  ======================================================== -->
</head>

<body class="index-page">

{% set archiveCount = collections.archives | length %}
{% set soonLabel = 'coming soon' if page.lang == 'en' else 'próximamente' %}

<header class="vault-zone site-header">
  {% include "navbar.njk" %}

  <section class="container-xl site-hero" id="about">
    <div>
      <h1 class="site-hero__title">Archivos Nuestros</h1>
      <div class="site-hero__intro">
        {{ content | safe }}
      </div>
    </div>

    <aside class="hero-stats">
      <p class="hero-stats__label">{% if page.lang == 'en' %}Current status{% else %}Estado real hoy{% endif %}</p>
      <p class="hero-stats__value">
        {% if page.lang == 'en' %}
          {% if archiveCount == 1 %}1 collection published{% else %}{{ archiveCount }} collections published{% endif %}
        {% else %}
          {% if archiveCount == 1 %}1 colección publicada{% else %}{{ archiveCount }} colecciones publicadas{% endif %}
        {% endif %}
      </p>
      <p class="hero-stats__note">{% if page.lang == 'en' %}La Vuelta hydroelectric photographs is the only published collection today.{% else %}La Vuelta hidroeléctrica es el prototipo público activo.{% endif %}</p>
    </aside>
  </section>
</header>

<section class="oxblood-ribbon theme-ribbon" aria-label="{% if page.lang == 'en' %}Thematic areas{% else %}Áreas temáticas{% endif %}">
  <div class="container-xl ribbon-grid">
    <span class="theme-chip disabled">Minería en el Chocó Colombiano <small>{{ soonLabel }}</small></span>
    <span class="theme-chip disabled">Mapas <small>{{ soonLabel }}</small></span>
    <span class="theme-chip disabled">En clave afro-diaspórica: Historia, cultura, visiones <small>{{ soonLabel }}</small></span>
    <span class="theme-chip disabled">Palenke el Congal <small>{{ soonLabel }}</small></span>
    <span class="theme-chip disabled">Archivo Catherine Legrande <small>{{ soonLabel }}</small></span>
  </div>
</section>

<main class="main">
  <section id="archives" class="reading-zone section-band">
    <div class="container-xl">
      <div class="section-title">
        <h2>{% if page.lang == 'en' %}Archival and Primary Materials{% else %}Materiales de Archivo y Fuentes Primarias{% endif %}</h2>
      </div>

      {% if archiveCount > 0 %}
      <div class="row g-4 archive-grid">
        {%- for archive in collections.archives | sort(attribute="data.title") -%}
        {% set archiveTitle = archive.data.titleEng if page.lang == 'en' and archive.data.titleEng else archive.data.title %}
        {% set archiveDesc = archive.data['desc-en'] if page.lang == 'en' and archive.data['desc-en'] else archive.data['desc-es'] %}
        <div class="col-xl-4 col-md-6 d-flex">
          <a href="{% if archive.data.link %}{{ archive.data.link }}{% else %}{{ archive.url | sitePath }}{% endif %}" class="archive-card-link d-flex flex-fill">
            <article class="doc-frame">
              <div class="doc-frame__media">
                {% if archive.data.thumbnail %}
                <img src="{{ archive.data.thumbnail | sitePath }}" class="img-fluid" alt="{{ archiveTitle }}">
                {% endif %}
              </div>
              <div class="doc-frame__body">
                {% if archive.data.date %}
                <div class="doc-frame__date">{{ archive.data.date | displayDate }}</div>
                {% endif %}
                <h3 class="doc-frame__title">{{ archiveTitle }}</h3>
                {% if archiveDesc %}
                <p class="doc-frame__summary">{{ archiveDesc }}</p>
                {% endif %}
                <div class="doc-frame__meta">
                  {% if archive.data.author %}
                  <span class="meta-chip">{{ archive.data.author }}</span>
                  {% endif %}
                  {% if archive.data.topic %}
                  <span class="meta-chip">{{ archive.data.topic }}</span>
                  {% endif %}
                  {% if archive.data.type %}
                  <span class="meta-chip">{{ archive.data.type }}</span>
                  {% endif %}
                </div>
              </div>
            </article>
          </a>
        </div>
        {%- endfor -%}
      </div>
      {% endif %}
    </section>
</main>

<section id="acknowledgements" class="acknowledgements-band">
  <div class="container-xl">
    <div class="section-title">
      <h2>{% if page.lang == 'en' %}Acknowledgements{% else %}Agradecimientos{% endif %}</h2>
    </div>
    {% if page.lang == 'en' %}
    <!-- DRAFT translation — pending approval -->
    <p>Archivo Afro received financial support from the Mellon Foundation's “Just Futures” initiative, grant N-2009-09221 for the project “Dispossessions in the Americas: the Extraction of Bodies, Land, and Heritage from la Conquista to the Present,” administered by the University of Pennsylvania and coordinated by Tulia Falleti. We also express gratitude for support from the Social Sciences and Humanities Research Council of Canada, Penn Libraries, the University of Pennsylvania, the University of New Brunswick, and the University of Michigan. Thanks to everyone: the youth group of Muntú Bantú, María Fernanda Parra, Sergio Mosquera Mosquera, Daniel Varela Corredor, Claudia Leal, Kelly López-Roldán, Ann Farnsworth-Alvear, Daniel Tubb, Cynthia Heider, Brie Gettleson, and Andy Janco.</p>
    {% else %}
    <p>Archivo Afro ha recibido apoyo financiero de la inciativa “Just Futures” de la Fundación Mellon, beca N-2009-09221 proyecto “Dispossessions in the Americas: the Extraction of Bodies, Land, and Heritage from la Conquista to the Present” administrada por la Universidad de Pensilvania y coordinada Tulia Falleti. También expresamos nuestra gratitud por el apoyo recibido del Social Sciences and Humanities Research Council of Canada, Penn Libraries, la Universidad de Pennsylvania, la Universidad de New Brunswick y la Universidad de Michigan. Gracias a todes: Las y los del Semillero de Jóvenes de Muntú Bantú, María Fernanda Parra, Sergio Mosquera Mosquera, Daniel Varela Corredor, Claudia Leal, Kelly López-Roldán, Ann Farnsworth-Alvear, Daniel Tubb, Cynthia Heider, Brie Gettleson, y Andy Janco.</p>
    {% endif %}
  </div>
</section>

  {% include 'footer.njk' %}

  <!-- Scroll Top -->
  <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

  <!-- Preloader -->
  <div id="preloader"></div>

  <!-- Vendor JS Files -->
  <script src="{{ '/assets/vendor/bootstrap/js/bootstrap.bundle.min.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/php-email-form/validate.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/aos/aos.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/swiper/swiper-bundle.min.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/glightbox/js/glightbox.min.js' | sitePath }}"></script>

  <!-- Main JS File -->
  <script src="{{ '/assets/js/main.js' | sitePath }}"></script>
  <script>
    window.addEventListener('DOMContentLoaded', (event) => {
        const searchContainer = document.getElementById('search');
        if (searchContainer) {
          new PagefindUI({ element: searchContainer, showSubResults: true });
        }
        const searchModal = document.getElementById('search-modal');
        const searchIcon = document.getElementById('search-icon');
        if (searchModal && searchIcon) {
          let myModal = new bootstrap.Modal(searchModal, {
            keyboard: false
          })
          searchIcon.addEventListener('click', function() {
            myModal.show();
          });
        }

    });
  </script>
  {% block extrajs %}{% endblock %}

</body>

</html>
