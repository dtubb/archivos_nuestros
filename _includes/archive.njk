---
layout: vanilla.njk
compactChrome: true
hideFooter: true
---

{% set record = null %}
{% for archive in collections.archives %}
  {% if archive.url == page.url %}
    {% set record = archive %}
  {% endif %}
{% endfor %}
{% if not record %}
  {% set record = collections.archives | first %}
{% endif %}

{% set recordTitle = record.data.titleEng if page.lang == 'en' and record.data.titleEng else record.data.title %}
{% set recordDesc = record.data['desc-en'] if page.lang == 'en' and record.data['desc-en'] else record.data['desc-es'] %}
{% set photoGrid = la_vuelta_photos if record.data.photoGrid == 'la_vuelta_photos' else [] %}
{% if record.data.type == 'photographs' or record.data.type == 'fotos' %}
  {% set recordTypeLabel = 'Photos' if page.lang == 'en' else 'Fotos' %}
{% elif page.lang == 'en' %}
  {% set recordTypeLabel = record.data.type or 'collection' %}
{% else %}
  {% set recordTypeLabel = record.data.type or 'colección' %}
{% endif %}
{% set recordSourceLabel = 'Source' if page.lang == 'en' else 'Fuente' %}
{% set recordSourceLinkLabel = 'Open source' if page.lang == 'en' else 'Abrir fuente' %}
{% set visiblePhotos = photoGrid | selectattr('thumbnail') | list %}

<article class="container-xl py-4 record-layout">
  <div class="row g-4 g-lg-5 align-items-start">
    <div class="col-lg-8 record-main">
      {% if visiblePhotos.length %}
      {% set firstPhoto = visiblePhotos | first %}
      <section class="photo-viewer" data-photo-viewer data-photo-count="{{ visiblePhotos | length }}">
        <button class="photo-viewer__open" type="button" data-photo-open aria-label="{% if page.lang == 'en' %}Open photograph viewer{% else %}Abrir visor de fotografía{% endif %}">
          <img
            src="{{ firstPhoto.thumbnail | sitePath }}"
            alt="{% if page.lang == 'en' %}Photograph{% else %}Fotografía{% endif %} {{ firstPhoto.sequence }}"
            data-photo-active-image
            data-photo-active-sequence="{{ firstPhoto.sequence }}"
            data-photo-active-position="1"
            data-photo-active-total="{{ visiblePhotos | length }}"
          >
        </button>
        <div class="photo-viewer__controls" data-photo-controls>
          <button class="photo-viewer__nav" type="button" data-photo-prev aria-label="{% if page.lang == 'en' %}Previous photograph{% else %}Fotografía anterior{% endif %}">
            <span aria-hidden="true">‹</span>
            <span class="visually-hidden">{% if page.lang == 'en' %}Previous photograph{% else %}Fotografía anterior{% endif %}</span>
          </button>
          <label class="photo-viewer__jump" for="photo-jump">
            <span class="visually-hidden">{% if page.lang == 'en' %}Jump to photograph{% else %}Ir a fotografía{% endif %}</span>
            <select class="photo-viewer__select" id="photo-jump" data-photo-jump aria-label="{% if page.lang == 'en' %}Jump to photograph{% else %}Ir a fotografía{% endif %}">
              {% for photo in visiblePhotos %}
              <option value="{{ loop.index0 }}"{% if loop.first %} selected{% endif %}>{{ photo.sequence }}</option>
              {% endfor %}
            </select>
          </label>
          <span class="photo-viewer__status" data-photo-status aria-live="polite">1 / {{ visiblePhotos | length }}</span>
          <button class="photo-viewer__nav" type="button" data-photo-next aria-label="{% if page.lang == 'en' %}Next photograph{% else %}Fotografía siguiente{% endif %}">
            <span aria-hidden="true">›</span>
            <span class="visually-hidden">{% if page.lang == 'en' %}Next photograph{% else %}Fotografía siguiente{% endif %}</span>
          </button>
        </div>
        <p class="photo-viewer__caption visually-hidden" data-photo-active-caption>{{ firstPhoto.sequence }}</p>
      </section>

      <div class="photo-lightbox-list" aria-hidden="true">
        {% for photo in visiblePhotos %}
          <a
            class="glightbox"
            href="{{ photo.thumbnail | sitePath }}"
            data-gallery="la-vuelta-photos"
            data-photo-lightbox-link
            data-photo-index="{{ loop.index0 }}"
            data-title="{{ recordTitle }}"
            data-description="{{ record.data.author }}. {{ photo.sequence }}."
          ></a>
        {% endfor %}
      </div>

      <div class="photo-grid" aria-label="{% if page.lang == 'en' %}Photographs{% else %}Fotografías{% endif %}">
        {% for photo in visiblePhotos %}
        <figure class="photo-grid__item">
          <button
            class="photo-grid__button{% if loop.first %} is-active{% endif %}"
            type="button"
            data-photo-thumb
            data-photo-index="{{ loop.index0 }}"
            data-photo-src="{{ photo.thumbnail | sitePath }}"
            data-photo-label="{% if page.lang == 'en' %}Photograph{% else %}Fotografía{% endif %} {{ photo.sequence }}"
            data-photo-caption="{{ photo.sequence }}"
            aria-label="{% if page.lang == 'en' %}Show photograph{% else %}Mostrar fotografía{% endif %} {{ photo.sequence }}"
          >
            <img src="{{ photo.thumbnail | sitePath }}" alt="{% if page.lang == 'en' %}Photograph{% else %}Fotografía{% endif %} {{ photo.sequence }}">
          </button>
          <figcaption>{{ photo.sequence }}</figcaption>
        </figure>
        {% endfor %}
      </div>
      {% elif record.data.thumbnail %}
      <figure class="record-thumb mb-4">
        <a class="glightbox" href="{{ record.data.thumbnail | sitePath }}" data-gallery="record-image">
          <img src="{{ record.data.thumbnail | sitePath }}" alt="{{ recordTitle }}" class="img-fluid">
        </a>
      </figure>
      {% endif %}

      {% if recordDesc %}
      <p class="record-lede mb-4">{{ recordDesc }}</p>
      {% endif %}

      {% if content | striptags | trim %}
      <div class="archive-body">
        {{ content | safe }}
      </div>
      {% endif %}
    </div>

    <aside class="col-lg-4 record-rail record-rail--right">
      <p class="eyebrow mb-2">{{ recordTypeLabel }}</p>
      <h1 class="record-title mb-3">{{ recordTitle }}</h1>

      <dl class="record-meta-list mb-0">
        {% if record.data.author %}
        <div>
          <dt>{% if page.lang == 'en' %}Creator{% else %}Creador{% endif %}</dt>
          <dd>{{ record.data.author }}</dd>
        </div>
        {% endif %}
        {% if record.data.topic %}
        <div>
          <dt>{% if page.lang == 'en' %}Topic{% else %}Tema{% endif %}</dt>
          <dd>{{ record.data.topic }}</dd>
        </div>
        {% endif %}
        {% if record.data.type %}
        <div>
          <dt>{% if page.lang == 'en' %}Type{% else %}Tipo{% endif %}</dt>
          <dd>{{ recordTypeLabel }}</dd>
        </div>
        {% endif %}
        {% if record.data.link %}
        <div>
          <dt>{{ recordSourceLabel }}</dt>
          <dd>
            <a class="record-meta-link" href="{{ record.data.link }}" rel="noreferrer" target="_blank" title="{{ record.data.link }}">
              {{ recordSourceLinkLabel }}
            </a>
          </dd>
        </div>
        {% endif %}
        {% if record.data.date %}
        <div>
          <dt>{% if page.lang == 'en' %}Date{% else %}Fecha{% endif %}</dt>
          <dd>{{ record.data.date | displayDate }}</dd>
        </div>
        {% endif %}
      </dl>
    </aside>
  </div>
</article>

<script>
  (() => {
    const viewer = document.querySelector('[data-photo-viewer]');
    if (!viewer) return;
    const page = viewer.closest('article.record-layout');
    if (!page) return;

    const activeImage = viewer.querySelector('[data-photo-active-image]');
    const activeCaption = viewer.querySelector('[data-photo-active-caption]');
    const activeStatus = viewer.querySelector('[data-photo-status]');
    const openButton = viewer.querySelector('[data-photo-open]');
    const prevButton = viewer.querySelector('[data-photo-prev]');
    const nextButton = viewer.querySelector('[data-photo-next]');
    const jumpSelect = viewer.querySelector('[data-photo-jump]');
    const thumbs = Array.from(page.querySelectorAll('[data-photo-thumb]'));
    const lightboxLinks = Array.from(page.querySelectorAll('[data-photo-lightbox-link]'));
    let activeIndex = 0;

    const syncControls = () => {
      const currentThumb = thumbs[activeIndex];
      if (!currentThumb) return;

      activeImage.src = currentThumb.dataset.photoSrc;
      activeImage.alt = currentThumb.dataset.photoLabel;
      activeImage.dataset.photoActiveSequence = currentThumb.dataset.photoCaption || '';
      activeImage.dataset.photoActivePosition = String(activeIndex + 1);
      activeImage.dataset.photoActiveTotal = String(thumbs.length);
      activeCaption.textContent = currentThumb.dataset.photoCaption;
      activeStatus.textContent = `${activeIndex + 1} / ${thumbs.length}`;
      jumpSelect.value = String(activeIndex);
      prevButton.disabled = activeIndex === 0;
      nextButton.disabled = activeIndex === thumbs.length - 1;
      thumbs.forEach((item) => {
        item.classList.toggle('is-active', item === currentThumb);
      });
    };

    const setActivePhoto = (index) => {
      if (index < 0 || index >= thumbs.length) return;
      activeIndex = index;
      syncControls();
    };

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        setActivePhoto(Number(thumb.dataset.photoIndex || 0));
      });
    });

    prevButton.addEventListener('click', () => setActivePhoto(activeIndex - 1));
    nextButton.addEventListener('click', () => setActivePhoto(activeIndex + 1));
    jumpSelect.addEventListener('change', () => setActivePhoto(Number(jumpSelect.value)));
    openButton.addEventListener('click', () => {
      lightboxLinks[activeIndex]?.click();
    });

    syncControls();
  })();
</script>
