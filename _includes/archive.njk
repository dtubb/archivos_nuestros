---
layout: vanilla.njk
compactChrome: true
hideFooter: true
---

{% set record = null %}
{% for archive in collections.archives %}
  {% if archive.url == page.url %}
    {% set record = archive %}
  {% endif %}
{% endfor %}
{% if not record %}
  {% set record = collections.archives | first %}
{% endif %}

{% set recordTitle = record.data.titleEng if page.lang == 'en' and record.data.titleEng else record.data.title %}
{% set recordDesc = record.data['desc-en'] if page.lang == 'en' and record.data['desc-en'] else record.data['desc-es'] %}
{% set recordRole = 'Creator / author' if page.lang == 'en' else 'Creador / autor' %}
{% set photoGrid = la_vuelta_photos if record.data.photoGrid == 'la_vuelta_photos' else [] %}
{% if record.data.type == 'photographs' %}
  {% set recordTypeLabel = 'Photographs' if page.lang == 'en' else 'Fotografías' %}
{% elif page.lang == 'en' %}
  {% set recordTypeLabel = record.data.type or 'collection' %}
{% else %}
  {% set recordTypeLabel = record.data.type or 'colección' %}
{% endif %}

<article class="container-xl py-4 record-layout">
  <div class="row g-4 g-lg-5 align-items-start">
    <aside class="col-lg-4 record-rail">
      <p class="eyebrow mb-2">{{ recordTypeLabel }}</p>
      <h1 class="record-title mb-3">{{ recordTitle }}</h1>

      <dl class="record-meta-list mb-0">
        {% if record.data.author %}
        <div>
          <dt>{% if page.lang == 'en' %}Creator{% else %}Creador{% endif %}</dt>
          <dd>{{ record.data.author }} · {{ recordRole }}</dd>
        </div>
        {% endif %}
        {% if record.data.topic %}
        <div>
          <dt>{% if page.lang == 'en' %}Topic{% else %}Tema{% endif %}</dt>
          <dd>{{ record.data.topic }}</dd>
        </div>
        {% endif %}
        {% if record.data.type %}
        <div>
          <dt>{% if page.lang == 'en' %}Type{% else %}Tipo{% endif %}</dt>
          <dd>{{ recordTypeLabel }}</dd>
        </div>
        {% endif %}
        {% if record.data.date %}
        <div>
          <dt>{% if page.lang == 'en' %}Date{% else %}Fecha{% endif %}</dt>
          <dd>{{ record.data.date | displayDate }}</dd>
        </div>
        {% endif %}
      </dl>
    </aside>

    <div class="col-lg-8 record-main">
      {% if record.data.thumbnail %}
      <figure class="record-thumb mb-4">
        <img src="{{ record.data.thumbnail | sitePath }}" alt="{{ recordTitle }}" class="img-fluid">
      </figure>
      {% endif %}

      {% set visiblePhotos = photoGrid | selectattr('thumbnail') | list %}
      {% if visiblePhotos.length %}
      <div class="photo-grid" aria-label="{% if page.lang == 'en' %}Photograph previews{% else %}Vistas previas de fotografías{% endif %}">
        {% for photo in visiblePhotos %}
        <figure class="photo-grid__item">
          <img src="{{ photo.thumbnail | sitePath }}" alt="{% if page.lang == 'en' %}Photograph{% else %}Fotografía{% endif %} {{ photo.sequence }}" loading="lazy">
          <figcaption>{{ photo.sequence }}</figcaption>
        </figure>
        {% endfor %}
      </div>
      {% endif %}

      {% if recordDesc %}
      <p class="record-lede mb-4">{{ recordDesc }}</p>
      {% endif %}

      {% if content | striptags | trim %}
      <div class="archive-body">
        {{ content | safe }}
      </div>
      {% endif %}
    </div>
  </div>
</article>
