---
layout: vanilla.njk
compactChrome: true
---

{% set record = null %}
{% for archive in collections.archives %}
  {% if archive.url == page.url %}
    {% set record = archive %}
  {% endif %}
{% endfor %}
{% if not record %}
  {% set record = collections.archives | first %}
{% endif %}

{% set recordTitle = record.data.titleEng if page.lang == 'en' and record.data.titleEng else record.data.title %}
{% set displayTitle = record.data.shortTitle or recordTitle %}
{% set recordDesc = record.data['desc-en'] if page.lang == 'en' and record.data['desc-en'] else record.data['desc-es'] %}
{% set photoGrid = photoGrids[record.data.photoGrid] or [] %}
{% set photoGalleryId = record.data.photoGrid or 'record-image' %}
{% set typeLabel = sections[record.data.type] %}
{% if typeLabel %}
  {% set recordTypeLabel = typeLabel.en if page.lang == 'en' else typeLabel.es %}
{% else %}
  {% set recordTypeLabel = record.data.type or ('collection' if page.lang == 'en' else 'colección') %}
{% endif %}
{% set recordSourceLabel = 'Source' if page.lang == 'en' else 'Fuente' %}
{% set recordSourceLinkLabel = 'Open source' if page.lang == 'en' else 'Abrir fuente' %}
{% set visiblePhotos = photoGrid | selectattr('thumbnail') | list %}
{% set firstPhoto = visiblePhotos | first %}
{% set sequenceLabel = 'sequence' if page.lang == 'en' else 'secuencia' %}
{% set citationKey = record.data.citationKey or record.fileSlug %}
{# Build BibTeX from cite_* fields; fall back to legacy bibtex field for back-compat #}
{% set citationBibtex = record.data | buildBibtex(citationKey) or record.data.bibtex %}

<div class="visually-hidden" aria-hidden="true">
  {% if record.data.type %}
  <span data-pagefind-meta="type">{{ record.data.type }}</span>
  <span data-pagefind-filter="type">{{ record.data.type }}</span>
  {% endif %}
  {% if record.data.author %}
  <span data-pagefind-meta="author">{{ record.data.author }}</span>
  <span data-pagefind-filter="author">{{ record.data.author }}</span>
  {% endif %}
  {% if record.data.topics %}
  <span data-pagefind-meta="topic">{{ record.data.topics | join(', ') }}</span>
    {% for topic in record.data.topics %}
  <span data-pagefind-filter="topic">{{ topic | trim }}</span>
    {% endfor %}
  {% endif %}
  {% if record.data.link %}
  <span data-pagefind-meta="source_link">{{ record.data.link }}</span>
  {% endif %}
  {% if visiblePhotos.length %}
  <span data-pagefind-meta="image">{{ firstPhoto.thumbnail | sitePath }}</span>
  {% elif record.data.thumbnail %}
  <span data-pagefind-meta="image">{{ record.data.thumbnail | sitePath }}</span>
  {% endif %}
</div>

<article class="container-xl py-4 record-layout" data-pagefind-body>
  {# Sub-collection filmstrip at the top: 3 before + current + 3 after, with prev/next arrows #}
  {%- set col = record.data.themes[0] if record.data.themes else null -%}
  {%- if col -%}
    {%- set sibs = [] -%}
    {%- for a in collections.archives -%}{%- if a.data.themes and col in a.data.themes -%}{%- set sibs = sibs.concat([a]) -%}{%- endif -%}{%- endfor -%}
    {%- set curIdx = 0 -%}
    {%- for a in sibs -%}{%- if a.url == page.url -%}{%- set curIdx = loop.index0 -%}{%- endif -%}{%- endfor -%}
    {%- set startI = curIdx - 3 -%}{%- if startI < 0 -%}{%- set startI = 0 -%}{%- endif -%}
    {%- set window = sibs.slice(startI, startI + 7) -%}
    {%- set prevRec = sibs[curIdx - 1] if curIdx > 0 else null -%}
    {%- set nextRec = sibs[curIdx + 1] if curIdx < (sibs.length - 1) else null -%}
    {% if sibs.length > 1 %}
    <nav class="record-filmstrip-bar" aria-label="{{ col }}">
      <a class="record-filmstrip__arrow{% if not prevRec %} is-disabled{% endif %}" {% if prevRec %}href="{{ prevRec.url | sitePath }}" data-subnav-prev{% endif %} aria-label="{% if page.lang == 'en' %}Previous{% else %}Anterior{% endif %}">‹</a>
      <div class="record-filmstrip">
        {% for a in window %}
        <a class="record-filmstrip__item{% if a.url == page.url %} is-current{% endif %}" href="{{ a.url | sitePath }}" title="{{ a.data.shortTitle or a.data.title }}">
          {% if a.data.thumbnail %}<img src="{{ a.data.thumbnail | sitePath }}" alt="{{ a.data.shortTitle or a.data.title }}" loading="lazy">{% else %}<span class="record-filmstrip__ph"><i class="bi bi-link-45deg"></i></span>{% endif %}
        </a>
        {% endfor %}
      </div>
      <a class="record-filmstrip__arrow{% if not nextRec %} is-disabled{% endif %}" {% if nextRec %}href="{{ nextRec.url | sitePath }}" data-subnav-next{% endif %} aria-label="{% if page.lang == 'en' %}Next{% else %}Siguiente{% endif %}">›</a>
    </nav>
    <script>
      (function () {
        document.addEventListener('keydown', function (e) {
          if (e.target.matches('input,textarea')) return;
          if (e.key === 'ArrowLeft') { var p = document.querySelector('[data-subnav-prev]'); if (p) p.click(); }
          if (e.key === 'ArrowRight') { var n = document.querySelector('[data-subnav-next]'); if (n) n.click(); }
        });
      })();
    </script>
    {% endif %}
  {%- endif -%}
  <div class="row g-4 g-lg-5 align-items-start">
    <div class="col-lg-8 record-main">
      {% if visiblePhotos.length %}
      {% set firstPhoto = visiblePhotos | first %}
      <section class="photo-viewer" data-photo-viewer aria-label="{% if page.lang == 'en' %}Photo gallery{% else %}Galería de fotografías{% endif %}">
        <div class="swiper photo-viewer__main" id="swiper-main-{{ photoGalleryId }}">
          <div class="swiper-wrapper">
            {% for photo in visiblePhotos %}
            <div class="swiper-slide">
              <a
                class="glightbox"
                href="{{ photo.thumbnail | sitePath }}"
                data-gallery="{{ photoGalleryId }}"
                data-title="{{ recordTitle }}"
                data-description="{{ record.data.author }}. {{ recordTitle }}. {{ sequenceLabel }} {{ photo.sequence }}."
                aria-label="{% if page.lang == 'en' %}Open full-screen: photograph{% else %}Abrir pantalla completa: fotografía{% endif %} {{ photo.sequence }}"
              ><img
                  src="{{ photo.thumbnail | sitePath }}"
                  alt="{% if page.lang == 'en' %}Photograph{% else %}Fotografía{% endif %} {{ photo.sequence }}"
                ></a>
            </div>
            {% endfor %}
          </div>
          <div class="photo-viewer__controls">
            <button class="swiper-button-prev photo-viewer__nav" aria-label="{% if page.lang == 'en' %}Previous photograph{% else %}Fotografía anterior{% endif %}"></button>
            <span class="photo-viewer__status" aria-live="polite">1 / {{ visiblePhotos | length }}</span>
            <button class="swiper-button-next photo-viewer__nav" aria-label="{% if page.lang == 'en' %}Next photograph{% else %}Fotografía siguiente{% endif %}"></button>
          </div>
        </div>
        <p class="photo-viewer__caption visually-hidden" aria-live="polite">{{ firstPhoto.sequence }}</p>
        <div class="swiper photo-grid photo-viewer__thumbs" id="swiper-thumbs-{{ photoGalleryId }}" hidden aria-label="{% if page.lang == 'en' %}Photographs{% else %}Fotografías{% endif %}">
          <div class="swiper-wrapper">
            {% for photo in visiblePhotos %}
            <div class="swiper-slide photo-grid__item">
              <img src="{{ photo.thumbnail | sitePath }}" alt="{% if page.lang == 'en' %}Photograph{% else %}Fotografía{% endif %} {{ photo.sequence }}">
              <figcaption>{{ photo.sequence }}</figcaption>
            </div>
            {% endfor %}
          </div>
        </div>
        {% if visiblePhotos.length > 1 %}
        <div class="photo-viewer__grid">
          {% for photo in visiblePhotos %}
          <a
            class="glightbox"
            href="{{ photo.thumbnail | sitePath }}"
            data-gallery="{{ photoGalleryId }}-grid"
            data-title="{{ recordTitle }}"
            data-description="{{ record.data.author }}. {{ recordTitle }}. {{ sequenceLabel }} {{ photo.sequence }}."
            aria-label="{% if page.lang == 'en' %}Open full-screen: photograph{% else %}Abrir pantalla completa: fotografía{% endif %} {{ photo.sequence }}"
          ><img src="{{ photo.thumbnail | sitePath }}" alt="{% if page.lang == 'en' %}Photograph{% else %}Fotografía{% endif %} {{ photo.sequence }}"></a>
          {% endfor %}
        </div>
        {% endif %}
      </section>
      {% elif record.data.thumbnail and not record.data.pdf and not record.data.video %}
      {% set fullImg = record.data.image or record.data.thumbnail %}
      <figure class="record-thumb mb-4">
        <a class="glightbox" href="{{ fullImg | sitePath }}" data-gallery="record-image">
          <img src="{{ record.data.thumbnail | sitePath }}" alt="{{ recordTitle }}" class="img-fluid">
        </a>
        {% if record.data.image %}<a class="record-thumb__download" href="{{ record.data.image | sitePath }}" download>{% if page.lang == 'en' %}Download original ↓{% else %}Descargar original ↓{% endif %}</a>{% endif %}
      </figure>
      {% endif %}

      {% if record.data.pdf %}
      {# ponytail: native browser PDF viewer via <iframe>. Self-hosted paths get sitePath; remote URLs pass through. #}
      {% set pdfSrc = record.data.pdf if '://' in record.data.pdf else (record.data.pdf | sitePath) %}
      <section class="record-pdf mb-4" aria-label="{% if page.lang == 'en' %}Document{% else %}Documento{% endif %}">
        <iframe class="record-pdf__frame" src="{{ pdfSrc }}" title="{{ recordTitle }}" loading="lazy"></iframe>
        <div class="record-pdf__actions">
          <button type="button" class="record-pdf__fs" onclick="(this.closest('.record-pdf').querySelector('.record-pdf__frame').requestFullscreen())">{% if page.lang == 'en' %}⛶ Fullscreen{% else %}⛶ Pantalla completa{% endif %}</button>
          <a class="record-pdf__download" href="{{ pdfSrc }}" target="_blank" rel="noreferrer">{% if page.lang == 'en' %}Open / download PDF{% else %}Abrir / descargar PDF{% endif %}</a>
        </div>
      </section>
      {% endif %}

      {% if record.data.video %}
      {% set videoSrc = record.data.video if '://' in record.data.video else (record.data.video | sitePath) %}
      <section class="record-video mb-4" aria-label="{% if page.lang == 'en' %}Video{% else %}Video{% endif %}">
        <video class="record-video__player" controls preload="metadata"{% if record.data.thumbnail %} poster="{{ record.data.thumbnail | sitePath }}"{% endif %}>
          <source src="{{ videoSrc }}" type="video/mp4">
        </video>
      </section>
      {% endif %}
      {% if record.data.audio %}
      {% set audioSrc = record.data.audio if '://' in record.data.audio else (record.data.audio | sitePath) %}
      <section class="record-audio mb-4" aria-label="Audio">
        <audio class="record-audio__player" controls preload="metadata" src="{{ audioSrc }}"></audio>
      </section>
      {% endif %}
      {% if recordDesc %}
      <p class="record-lede mb-4">{{ recordDesc }}</p>
      {% endif %}

      {% set catalogueText = record.data['catalogue-en'] if page.lang == 'en' and record.data['catalogue-en'] else record.data['catalogue-es'] %}
      {% set catalogueOrigin = record.data['catalogue-origin'] %}
      {% if catalogueText %}
      <details class="record-details mb-3">
        <summary class="record-details__summary">
          Catálogo / Catalogue
          {% if catalogueOrigin == 'ai' %}<span class="origin-badge">con apoyo de IA / AI-assisted</span>{% endif %}
        </summary>
        <div class="record-details__body">{{ catalogueText | md | safe }}</div>
      </details>
      {% endif %}

      {% set transcriptionText = record.data['transcription-en'] if page.lang == 'en' and record.data['transcription-en'] else record.data['transcription-es'] %}
      {% set transcriptionOrigin = record.data['transcription-origin'] %}
      {% if transcriptionText %}
      <details class="record-details mb-3">
        <summary class="record-details__summary">
          Transcripción / Transcription
          {% if transcriptionOrigin == 'ai' %}<span class="origin-badge">con apoyo de IA / AI-assisted</span>{% endif %}
        </summary>
        <div class="record-details__body">{{ transcriptionText | md | safe }}</div>
      </details>
      {% endif %}

      {% if content | striptags | trim %}
      <div class="archive-body">
        {{ content | safe }}
      </div>
      {% endif %}
    </div>

    <aside class="col-lg-4 record-rail record-rail--right">
      <p class="eyebrow mb-2">{% if record.data.themes %}{{ record.data.themes | join(' · ') }} · {% endif %}{{ recordTypeLabel }}</p>
      <h1 class="record-title mb-3" data-pagefind-meta="title">{{ displayTitle }}</h1>

      <dl class="record-meta-list mb-0">
        {% if record.data.author %}
        <div>
          <dt>{% if page.lang == 'en' %}Creator{% else %}Creador{% endif %}</dt>
          <dd>{{ record.data.author }}</dd>
        </div>
        {% endif %}
        {% if record.data.topics %}
        <div>
          <dt>{% if page.lang == 'en' %}Topic{% else %}Tema{% endif %}</dt>
          <dd>{{ record.data.topics | join(', ') }}</dd>
        </div>
        {% endif %}
        {% if record.data.material %}
        <div>
          <dt>{% if page.lang == 'en' %}Material{% else %}Material{% endif %}</dt>
          <dd>{{ record.data.material }}</dd>
        </div>
        {% endif %}
        {% if record.data.source %}
        <div>
          <dt>{% if page.lang == 'en' %}Source{% else %}Fuente{% endif %}</dt>
          <dd>{{ record.data.source }}</dd>
        </div>
        {% endif %}
        {% if record.data.type %}
        <div>
          <dt>{% if page.lang == 'en' %}Type{% else %}Tipo{% endif %}</dt>
          <dd>{{ recordTypeLabel }}</dd>
        </div>
        {% endif %}
        {% if record.data.link %}
        <div>
          <dt>{{ recordSourceLabel }}</dt>
          <dd>
            <a class="record-meta-link" href="{{ record.data.link }}" rel="noreferrer" target="_blank" title="{{ record.data.link }}">
              {{ recordSourceLinkLabel }}
            </a>
          </dd>
        </div>
        {% endif %}
        {% if record.data.displayDate %}
        <div>
          <dt>{% if page.lang == 'en' %}Date{% else %}Fecha{% endif %}</dt>
          <dd>{{ record.data.displayDate }}</dd>
        </div>
        {% endif %}
        {% if record.data.themes %}
        <div>
          <dt>{% if page.lang == 'en' %}Themes{% else %}Temas{% endif %}</dt>
          <dd>{{ record.data.themes | join(' · ') }}</dd>
        </div>
        {% endif %}
        {% if record.data.access %}
        <div>
          <dt>{% if page.lang == 'en' %}Access{% else %}Acceso{% endif %}</dt>
          <dd>{{ record.data.access }}{% if record.data.contact %} — <a class="record-meta-link" href="mailto:{{ record.data.contact }}">{{ record.data.contact }}</a>{% endif %}</dd>
        </div>
        {% endif %}
        {% if record.data.shorthand %}
        <div>
          <dt>{% if page.lang == 'en' %}Shorthand{% else %}Sigla{% endif %}</dt>
          <dd>{{ record.data.shorthand }}</dd>
        </div>
        {% endif %}
      </dl>

      {% if citationBibtex %}
      <div class="record-citation-block">
        <h2>{% if page.lang == 'en' %}Citation{% else %}Cita{% endif %}</h2>
        <div class="citation-formatted">{{ citationBibtex | citeStyle('chicago-author-date') | safe }}</div>
        <a class="record-citation-download" download="{{ citationKey }}.bib"
           href="data:text/plain;charset=utf-8,{{ citationBibtex | urlEncode }}"
        >{% if page.lang == 'en' %}Download BibTeX{% else %}Descargar BibTeX{% endif %}</a>
      </div>
      {% endif %}

    </aside>
  </div>

  {# Source-archive metadata — full width at the bottom, always open #}
  {% set srcMeta = source_meta[record.fileSlug] %}
  {% if srcMeta %}
  <section class="record-source-full">
    <h2 class="record-source__title">{% if page.lang == 'en' %}Source archive{% else %}Archivo fuente{% endif %}</h2>
    {% if srcMeta.source_archive %}<p class="record-source__archive">{{ srcMeta.source_archive }}</p>{% endif %}
    <dl class="record-source__meta">{% for f in srcMeta.fields %}{% if f.value %}<dt>{{ f.label }}</dt><dd>{{ f.value }}</dd>{% endif %}{% endfor %}</dl>
    {% if srcMeta.record_url %}<a class="record-source__link" href="{{ srcMeta.record_url }}" target="_blank" rel="noreferrer">{% if page.lang == 'en' %}View in source archive ↗{% else %}Ver en el archivo fuente ↗{% endif %}</a>{% endif %}
  </section>
  {% endif %}
</article>

<script>
  window.addEventListener('load', () => {
    const mainEl = document.getElementById('swiper-main-{{ photoGalleryId }}');
    const thumbEl = document.getElementById('swiper-thumbs-{{ photoGalleryId }}');
    const gridEl = mainEl?.closest('.photo-viewer')?.querySelector('.photo-viewer__grid');
    const toggleBtns = mainEl?.closest('.photo-viewer')?.querySelectorAll('[data-viewer-mode]');
    if (toggleBtns) {
      toggleBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const mode = btn.dataset.viewerMode;
          toggleBtns.forEach(b => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
          const isGrid = mode === 'grid';
          [mainEl, thumbEl, mainEl?.querySelector('.photo-viewer__caption')].forEach(el => {
            if (el) el.hidden = isGrid;
          });
          mainEl?.closest('.photo-viewer')?.querySelector('.photo-viewer__controls') && (mainEl.querySelector('.photo-viewer__controls').hidden = isGrid);
          if (gridEl) gridEl.hidden = !isGrid;
        });
      });
    }
    if (!mainEl || !thumbEl || typeof Swiper === 'undefined') return;

    const statusEl = mainEl.querySelector('.photo-viewer__status');
    const captionEl = mainEl.closest('.photo-viewer')?.querySelector('.photo-viewer__caption');

    const thumbSwiper = new Swiper(thumbEl, {
      slidesPerView: 'auto',
      spaceBetween: 8,
      watchSlidesProgress: true,
      freeMode: true,
    });

    const mainSwiper = new Swiper(mainEl, {
      thumbs: { swiper: thumbSwiper },
      keyboard: { enabled: true },
      navigation: {
        prevEl: mainEl.querySelector('.swiper-button-prev'),
        nextEl: mainEl.querySelector('.swiper-button-next'),
      },
      on: {
        slideChange() {
          const idx = this.activeIndex;
          if (statusEl) statusEl.textContent = `${idx + 1} / ${this.slides.length}`;
          const thumbSlide = thumbSwiper.slides[idx];
          if (captionEl && thumbSlide) captionEl.textContent = thumbSlide.querySelector('figcaption')?.textContent || '';
        },
      },
    });
  });
</script>
