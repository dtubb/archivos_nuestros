---
layout: vanilla.njk
---

{% set record = null %}
{% for archive in collections.archives %}
  {% if archive.url == page.url %}
    {% set record = archive %}
  {% endif %}
{% endfor %}
{% if not record %}
  {% set record = collections.archives | first %}
{% endif %}

{% set recordTitle = record.data.titleEng if page.lang == 'en' and record.data.titleEng else record.data.title %}
{% set recordDesc = record.data['desc-en'] if page.lang == 'en' and record.data['desc-en'] else record.data['desc-es'] %}
{% set recordRole = 'Creator / author' if page.lang == 'en' else 'Creador / autor' %}
{% set noteLabel = 'Linked originals' if page.lang == 'en' else 'Originales enlazados' %}
{% set noteBody = 'Full-resolution originals are linked and hosted externally in Box. Only the thumbnail is hosted here.' if page.lang == 'en' else 'Los originales en alta resolución están enlazados y alojados externamente en Box. Aquí solo se hospeda la miniatura.' %}
{% if page.lang == 'en' %}
{% set recordTypeLabel = record.data.type or 'collection' %}
{% else %}
{% set recordTypeLabel = record.data.type or 'colección' %}
{% endif %}

<article class="container-xl py-5">
  <div class="row justify-content-center">
    <div class="col-xl-10">
      <div class="row g-5 align-items-start">
        <div class="col-lg-5">
          {% if record.data.thumbnail %}
          <figure class="doc-frame mb-0">
            <div class="doc-frame__media">
              <img src="{{ record.data.thumbnail | sitePath }}" alt="{{ recordTitle }}">
            </div>
          </figure>
          {% endif %}
        </div>

        <div class="col-lg-7">
          <p class="eyebrow">{{ recordTypeLabel }}</p>
          <h1 class="mb-3">{{ recordTitle }}</h1>

          {% if record.data.date %}
          <p class="doc-frame__date mb-3">{{ record.data.date | displayDate }}</p>
          {% endif %}

          <div class="d-flex flex-wrap gap-2 mb-4">
            {% if record.data.author %}
            <span class="meta-chip">{{ record.data.author }} · {{ recordRole }}</span>
            {% endif %}
            {% if record.data.topic %}
            <span class="meta-chip">{{ record.data.topic }}</span>
            {% endif %}
            {% if record.data.type %}
            <span class="meta-chip">{{ record.data.type }}</span>
            {% endif %}
          </div>

          {% if recordDesc %}
          <p class="lead mb-4">{{ recordDesc }}</p>
          {% endif %}

          <section class="mb-4">
            <h2 class="h4 mb-2">{{ noteLabel }}</h2>
            <p class="text-sage mb-0">{{ noteBody }} <!-- TODO: external originals link --></p>
          </section>

          <div class="archive-body">
            {{ content | safe }}
          </div>

          {% if record.data.link %}
          <p class="mt-4">
            <a href="{{ record.data.link }}" class="readmore">
              <span>{% if page.lang == 'en' %}Open external record{% else %}Abrir registro externo{% endif %}</span><i class="bi bi-arrow-right"></i>
            </a>
          </p>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</article>
