---
layout: vanilla.njk
---

<article class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-9">
      <p class="eyebrow">{{ type or "collection" }}</p>
      <h1 class="mb-3">{{ title }}</h1>
      {% if page.lang == 'en' and titleEng %}
      <p class="mb-3"><em>{{ titleEng }}</em></p>
      {% endif %}

      <div class="meta d-flex flex-wrap gap-3 mb-4">
        {% if author %}
        <span><i class="bi bi-person"></i> {{ author }}</span>
        {% endif %}
        {% if topic %}
        <span><i class="bi bi-folder2"></i> {{ topic }}</span>
        {% endif %}
        {% if date %}
        <span><i class="bi bi-calendar4"></i> {{ date }}</span>
        {% endif %}
      </div>

      {% if thumbnail %}
      <figure class="mb-4">
        <img src="{{ thumbnail }}" alt="{{ title }}" class="img-fluid">
      </figure>
      {% endif %}

      {% if page.lang == 'en' and desc-en %}
      <p>{{ desc-en }}</p>
      {% elif desc-es %}
      <p>{{ desc-es }}</p>
      {% endif %}

      <div class="archive-body">
        {{ content | safe }}
      </div>

      {% if link %}
      <p class="mt-4">
        <a href="{{ link }}" class="readmore">
          <span>{% if page.lang == 'en' %}Open collection record{% else %}Abrir registro de la colección{% endif %}</span><i class="bi bi-arrow-right"></i>
        </a>
      </p>
      {% endif %}
    </div>
  </div>
</article>
