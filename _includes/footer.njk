<footer id="footer" class="footer dark-background">
  <div class="footer-top">
    <div class="container">
      <div class="row gy-4">

        <div class="col-lg-2 col-md-6">
          <p class="footer-support-group-label">{% if page.lang == 'en' %}Conveners{% else %}Convocantes{% endif %}</p>
          <ul class="footer-support-list">
            {% for person in site.conveners %}<li>{{ person }}</li>
            {% endfor %}
          </ul>
        </div>

        <div class="col-lg-3 col-md-6">
          <p class="footer-support-group-label">{% if page.lang == 'en' %}Curators{% else %}Curadores{% endif %}</p>
          <ul class="footer-support-list">
            {% for curator in site.curators %}<li>{{ curator }}</li>
            {% endfor %}
          </ul>
        </div>

        <div class="col-lg-2 col-md-6">
          <p class="footer-support-group-label">{% if page.lang == 'en' %}Special thanks{% else %}Agradecimientos especiales{% endif %}</p>
          <ul class="footer-support-list">
            {% for person in site.special_thanks %}<li>{{ person }}</li>
            {% endfor %}
          </ul>
        </div>

        <div class="col-lg-5 col-md-12">
          <p class="footer-support-group-label">{% if page.lang == 'en' %}Financial support{% else %}Apoyo financiero{% endif %}</p>
          <p class="footer-support-intro">{% if page.lang == 'en' %}{{ site.funders_intro_en }}{% else %}{{ site.funders_intro_es }}{% endif %}</p>
          <ul class="footer-support-list">
            {% for funder in site.funders %}<li><a href="{{ funder.url }}" rel="noreferrer" target="_blank">{{ funder.name }}</a></li>
            {% endfor %}
          </ul>
        </div>

      </div>
    </div>
  </div>
</footer>
