<footer id="footer" class="footer dark-background">
  <div class="footer-top">
    <div class="container">
      <div class="row gy-4">

        <div class="col-lg-3 col-md-6">
          <p class="mb-2"><strong>{% if page.lang == 'en' %}Project{% else %}Proyecto{% endif %}</strong></p>
          <p class="mb-2">Ann Farnsworth-Alvear</p>
          <p class="mb-0">Daniel Tubb</p>
        </div>

        <div class="col-lg-9 col-md-12">
          {% if page.lang == 'en' %}
          <h4>Supporters</h4>
          <div class="row gy-3">
            <div class="col-sm-6">
              <p class="footer-support-group-label">Funders</p>
              <ul class="footer-support-list">
                {% for funder in site.funders %}<li>{{ funder }}</li>
                {% endfor %}
              </ul>
            </div>
            <div class="col-sm-6">
              <p class="footer-support-group-label">Partner Institutions</p>
              <ul class="footer-support-list">
                {% for partner in site.partners %}<li>{{ partner }}</li>
                {% endfor %}
              </ul>
              <p class="footer-attribution mt-3">{{ site.attribution }}</p>
            </div>
          </div>
          {% else %}
          <h4>Apoyos</h4>
          <div class="row gy-3">
            <div class="col-sm-6">
              <p class="footer-support-group-label">Apoyos institucionales</p>
              <ul class="footer-support-list">
                {% for funder in site.funders %}<li>{{ funder }}</li>
                {% endfor %}
              </ul>
            </div>
            <div class="col-sm-6">
              <p class="footer-support-group-label">Instituciones aliadas</p>
              <ul class="footer-support-list">
                {% for partner in site.partners %}<li>{{ partner }}</li>
                {% endfor %}
              </ul>
              <p class="footer-attribution mt-3">{{ site.attribution }}</p>
            </div>
          </div>
          {% endif %}
        </div>

      </div>
    </div>
  </div>
</footer>
