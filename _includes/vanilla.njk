<!DOCTYPE html>
<html lang="{{ page.lang }}">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>{{ title or metadata.title or 'Archivos con Vida' }}</title>
  <meta content="" name="description">
  <meta content="" name="keywords">

  <link href="{{ '/assets/img/apple-touch-icon.png' | sitePath }}" rel="icon">
  <link href="{{ '/assets/img/apple-touch-icon.png' | sitePath }}" rel="apple-touch-icon">

  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap" rel="stylesheet">

  <link href="{{ '/assets/vendor/bootstrap/css/bootstrap.min.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/bootstrap-icons/bootstrap-icons.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/aos/aos.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/swiper/swiper-bundle.min.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/vendor/glightbox/css/glightbox.min.css' | sitePath }}" rel="stylesheet">

  <link href="{{ '/assets/css/main.css' | sitePath }}" rel="stylesheet">
  <link href="{{ '/assets/css/archivos.css' | sitePath }}" rel="stylesheet">

  {% block extracss %}{% endblock %}

  <link href="{{ '/pagefind/pagefind-ui.css' | sitePath }}" rel="stylesheet">
  <script src="{{ '/pagefind/pagefind-ui.js' | sitePath }}" type="text/javascript"></script>
</head>

<body class="index-page">

<header class="vault-zone site-header {% if compactChrome %}site-header--compact{% endif %}">
 {% include "navbar.njk" %}
</header>

<main class="main reading-zone {% if compactChrome %}record-shell{% endif %}">
  {{ content | safe }}
</main>

  {% if not hideFooter %}
  {% include 'footer.njk' %}
  {% endif %}

  {% if not hideFooter %}
  <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>
  {% endif %}

  <script src="{{ '/assets/vendor/bootstrap/js/bootstrap.bundle.min.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/aos/aos.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/swiper/swiper-bundle.min.js' | sitePath }}"></script>
  <script src="{{ '/assets/vendor/glightbox/js/glightbox.min.js' | sitePath }}"></script>

  <script src="{{ '/assets/js/main.js' | sitePath }}"></script>
  <script>
    window.addEventListener('DOMContentLoaded', (event) => {
      const searchContainer = document.getElementById('search');
      if (searchContainer) {
        new PagefindUI({ element: searchContainer, showSubResults: true });
      }
      const searchModal = document.getElementById('search-modal');
      const searchIcon = document.getElementById('search-icon');
      if (searchModal && searchIcon) {
        let myModal = new bootstrap.Modal(searchModal, {
          keyboard: false
        })
        searchIcon.addEventListener('click', function() {
          myModal.show();
        });
      }
    });
  </script>
  {% block extrajs %}{% endblock %}

</body>

</html>
