{% set is_en = page.lang == 'en' %}
{% set home_url = '/en/' if is_en else '/' %}
{% set archives_url = '/en/archives/' if is_en else '/archives/' %}
{% set people_url = '/en/personas/' if is_en else '/personas/' %}
{% set search_url = '/en/search/' if is_en else '/buscar/' %}
{% set nav_archives = 'Sources' if is_en else 'Fuentes' %}
{% set nav_people = 'People' if is_en else 'Personas' %}
{% set nav_search = 'Search' if is_en else 'Buscar' %}

<div class="container-xl">
  <div class="site-topbar">
    <a href="{{ home_url | sitePath }}" class="site-brand">Archivos Nuestros</a>

    <nav class="site-nav" aria-label="Primary">
      <a class="site-nav__link chip {% if page.url == archives_url %}is-current{% endif %}" href="{{ archives_url | sitePath }}">{{ nav_archives }}</a>
      <a class="site-nav__link chip" href="{{ people_url | sitePath }}">{{ nav_people }}</a>
      <a class="site-nav__link chip {% if page.url == search_url %}is-current{% endif %}" href="{{ search_url | sitePath }}">{{ nav_search }}</a>
      <a class="site-nav__link site-nav__toggle chip {% if is_en %}{% else %}is-current{% endif %}" href="{{ '/' | sitePath }}">ES</a>
      <a class="site-nav__link site-nav__toggle chip {% if is_en %}is-current{% endif %}" href="{{ '/en/' | sitePath }}">EN</a>
    </nav>
  </div>
</div>
