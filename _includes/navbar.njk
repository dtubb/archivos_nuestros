  <header id="header" class="header d-flex align-items-center position-relative">
    <div class="container-fluid container-xl position-relative d-flex align-items-center justify-content-between">

      <a href="index.html" class="logo d-flex align-items-center">
        <!-- Uncomment the line below if you also wish to use an image logo -->
        <img class="img-fluid" src="{{ '/assets/img/colombia-outline.png' | sitePath }}" alt="Archivos Nuestros">
        <h1 class="sitename">Archivos Nuestros</h1>
      </a>

      <nav id="navmenu" class="navmenu">
        <ul>
            
        <li><i id="search-icon" class="bi bi-search"></i></li>

          {% if page.lang == 'en' %}
        <a href="{{ '/en/' | sitePath }}">english</a> | <a href="{{ '/' | sitePath }}">español</a>
         
          {% else %}
        <a href="{{ '/' | sitePath }}">español</a> | <a href="{{ '/en/' | sitePath }}">english</a>
         {% endif %}
         
        </ul>
        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>

      </nav>

    </div>

  </header>
