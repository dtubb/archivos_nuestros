---
layout: vanilla.njk
---

{% set archiveItems = collections.archives | sort(attribute="data.title") %}
{% set archiveTypes = [] %}
{% set archivePlaces = [] %}
{% for archive in archiveItems %}
  {% if archive.data.type and archive.data.type not in archiveTypes %}
    {% set archiveTypes = archiveTypes.concat([archive.data.type]) %}
  {% endif %}
  {% if archive.data.place and archive.data.place not in archivePlaces %}
    {% set archivePlaces = archivePlaces.concat([archive.data.place]) %}
  {% endif %}
{% endfor %}

<div class="wrapper home">
  <div class="content">
    <section class="reading-zone section-band archives-browse">
      <div class="container-xl">
        <div class="section-title d-flex flex-wrap justify-content-between align-items-end gap-3">
          <div>
            <h1 class="mb-0">{% if page.lang == 'en' %}Primary Sources{% else %}Fuentes primarias{% endif %}</h1>
          </div>

          <div class="archive-toolbar">
            {% if archivePlaces.length > 1 %}
            <div class="archive-place-filters" role="group" aria-label="{% if page.lang == 'en' %}Filter archives by place{% else %}Filtrar archivos por lugar{% endif %}">
              <span class="archive-filter-label">{% if page.lang == 'en' %}Place{% else %}Lugar{% endif %}</span>
              <button class="ui-chip place-filter is-active" type="button" data-place-filter="all">
                {% if page.lang == 'en' %}All{% else %}Todas{% endif %}
              </button>
              {% for place in archivePlaces %}
              <button class="ui-chip place-filter" type="button" data-place-filter="{{ place }}">{{ place }}</button>
              {% endfor %}
            </div>
            {% endif %}
            {% if archiveTypes.length > 1 %}
            <div class="archive-filters" role="group" aria-label="{% if page.lang == 'en' %}Filter archives by type{% else %}Filtrar archivos por tipo{% endif %}">
              <button class="ui-chip archive-filter is-active" type="button" data-archive-filter="all">
                {% if page.lang == 'en' %}All{% else %}Todas{% endif %}
              </button>
              {% for type in archiveTypes %}
              {% set chipSection = sections[type] %}
              <button class="ui-chip archive-filter" type="button" data-archive-filter="{{ type }}">{{ (chipSection.en if page.lang == 'en' else chipSection.es) if chipSection else type }}</button>
              {% endfor %}
            </div>
            {% endif %}
            <div class="archive-view-toggle" role="group" aria-label="{% if page.lang == 'en' %}Archive view{% else %}Vista del archivo{% endif %}">
              <button class="ui-chip archive-view-button is-active" type="button" data-archive-view="grid">
                {% if page.lang == 'en' %}Grid{% else %}Cuadrícula{% endif %}
              </button>
              <button class="ui-chip archive-view-button" type="button" data-archive-view="table">
                {% if page.lang == 'en' %}Table{% else %}Tabla{% endif %}
              </button>
            </div>
          </div>
        </div>

        <div class="archive-view-panel is-active" data-archive-view-panel="grid">
          <div class="row g-4 archive-grid archives-browse__grid" data-archive-grid>
            {%- for archive in archiveItems -%}
            {% set archiveTitle = archive.data.titleEng if page.lang == 'en' and archive.data.titleEng else archive.data.title %}
            <div class="col-xl-4 col-md-6 d-flex archive-item" data-archive-item data-archive-type="{{ archive.data.type or '' }}" data-archive-place="{{ archive.data.place or '' }}">
              <a href="{{ archive.url | sitePath }}" class="archive-card-link d-flex flex-fill">
                <article class="doc-frame">
                  <div class="doc-frame__media">
                    {% if archive.data.thumbnail %}
                    <img src="{{ archive.data.thumbnail | sitePath }}" class="img-fluid" alt="{{ archiveTitle }}">
                    {% endif %}
                  </div>
                  <div class="doc-frame__body">
                    <h2 class="doc-frame__title">{{ archive.data.shortTitle or archiveTitle }}</h2>
                    {% set cardSection = sections[archive.data.type] %}
                    {% if archive.data.place or cardSection %}
                    <p class="doc-frame__breadcrumb">{% if archive.data.place %}{{ archive.data.place }}{% endif %}{% if archive.data.place and cardSection %} · {% endif %}{% if cardSection %}{{ cardSection.en if page.lang == 'en' else cardSection.es }}{% endif %}</p>
                    {% endif %}
                  </div>
                </article>
              </a>
            </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="archive-view-panel" data-archive-view-panel="table">
          <div class="archive-table-wrap">
            <table class="archive-table">
              <thead>
                <tr>
                  <th scope="col">{% if page.lang == 'en' %}Title{% else %}Título{% endif %}</th>
                  <th scope="col">{% if page.lang == 'en' %}Creator{% else %}Creador{% endif %}</th>
                  <th scope="col">{% if page.lang == 'en' %}Type{% else %}Tipo{% endif %}</th>
                  <th scope="col">{% if page.lang == 'en' %}Source{% else %}Fuente{% endif %}</th>
                </tr>
              </thead>
              <tbody>
                {%- for archive in archiveItems -%}
                {% set archiveTitle = archive.data.titleEng if page.lang == 'en' and archive.data.titleEng else archive.data.title %}
                <tr class="archive-item" data-archive-item data-archive-type="{{ archive.data.type or '' }}" data-archive-place="{{ archive.data.place or '' }}">
                  <td><a href="{{ archive.url | sitePath }}">{{ archive.data.shortTitle or archiveTitle }}</a></td>
                  <td>{{ archive.data.author or '' }}</td>
                  {% set rowSection = sections[archive.data.type] %}
                  <td>{{ (rowSection.en if page.lang == 'en' else rowSection.es) if rowSection else (archive.data.type or '') }}</td>
                  <td>
                    {% if archive.data.link %}
                    <a data-archive-source-link href="{{ archive.data.link }}" rel="noreferrer" target="_blank">{% if page.lang == 'en' %}Source{% else %}Fuente{% endif %}</a>
                    {% endif %}
                  </td>
                </tr>
                {%- endfor -%}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

<script>
  (() => {
    const filterButtons = Array.from(document.querySelectorAll('[data-archive-filter]'));
    const placeButtons = Array.from(document.querySelectorAll('[data-place-filter]'));
    const items = Array.from(document.querySelectorAll('[data-archive-item]'));
    const viewButtons = Array.from(document.querySelectorAll('[data-archive-view]'));
    const viewPanels = Array.from(document.querySelectorAll('[data-archive-view-panel]'));
    if (!items.length) return;

    let activeType = 'all';
    let activePlace = 'all';

    const applyFilters = () => {
      items.forEach((item) => {
        const typeMatch = activeType === 'all' || (item.dataset.archiveType || '') === activeType;
        const placeMatch = activePlace === 'all' || (item.dataset.archivePlace || '') === activePlace;
        item.classList.toggle('is-hidden', !(typeMatch && placeMatch));
      });
    };

    const setActiveFilter = (filter) => {
      activeType = filter;
      filterButtons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.archiveFilter === filter);
      });
      applyFilters();
    };

    const setActivePlace = (place) => {
      activePlace = place;
      placeButtons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.placeFilter === place);
      });
      applyFilters();
    };

    const setActiveView = (view) => {
      viewButtons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.archiveView === view);
      });

      viewPanels.forEach((panel) => {
        panel.classList.toggle('is-active', panel.dataset.archiveViewPanel === view);
      });
    };

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => setActiveFilter(button.dataset.archiveFilter || 'all'));
    });
    placeButtons.forEach((button) => {
      button.addEventListener('click', () => setActivePlace(button.dataset.placeFilter || 'all'));
    });
    viewButtons.forEach((button) => {
      button.addEventListener('click', () => setActiveView(button.dataset.archiveView || 'grid'));
    });

    setActiveFilter('all');
    setActivePlace('all');
    setActiveView('grid');
  })();
</script>
